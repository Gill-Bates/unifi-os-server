# UniFi OS Server Build Configuration
# ====================================

# Ubiquiti Download API - source of truth for installer URLs
DOWNLOAD_API_URL=https://download.svc.ui.com/v1/downloads/products/slugs/unifi-os-server

# Target platforms for multi-arch builds
# linux/arm64 and QUEMEU does not work well together, so we build separately for each architecture and load the image directly instead of pushing/pulling from a registry.
PLATFORMS=linux/amd64

# Docker image name
IMAGE_NAME=giiibates/unifi-os-server
